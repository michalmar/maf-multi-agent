subscription_id = "<your-azure-subscription-id>"
acr_name        = "mafdemo<unique-suffix>"   # must be globally unique, alphanumeric only

# Reuse your existing AI services
project_endpoint                     = "https://<your-foundry-endpoint>.services.ai.azure.com/api/projects/<project>"
azure_openai_chat_deployment_name    = "gpt-5.2"
azure_openai_summary_deployment_name = "gpt-4.1-nano"

# Optional: full resource ID for automatic RBAC assignment
# ai_services_resource_id = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>"

# ── Fabric Data Agent ──────────────────────────────────────────
# enable_fabric_data_agent  = true
# fabric_data_agent_mcp_url = "https://api.fabric.microsoft.com/v1/mcp/workspaces/<id>/dataagents/<id>/agent"

# Fabric capacity status check (optional — enables green/red indicator in UI)
# fabric_capacity_resource_id = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Fabric/capacities/<name>"

# ── Easy Auth (Entra ID login + Fabric user tokens) ───────────
# Gates the entire app behind Entra ID login. Required for Fabric Data Agent
# in production (Fabric requires user identity tokens for data queries).
#
# Terraform creates: Entra app registration, client secret, admin consent
# grants, token store (storage account), and ACA Easy Auth configuration.
#
# After apply, run: ./post_infra_deploy.sh
# One manual step: add the MI to your Fabric workspace as Admin.

# enable_easy_auth = true
# easyauth_storage_account_name = ""  # auto-generated if empty
