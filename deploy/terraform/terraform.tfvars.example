subscription_id = "<your-azure-subscription-id>"
acr_name        = "mafdemo<unique-suffix>"   # must be globally unique, alphanumeric only

# Reuse your existing AI services
project_endpoint                     = "https://<your-foundry-endpoint>.services.ai.azure.com/api/projects/<project>"
azure_openai_chat_deployment_name    = "gpt-5.2"
azure_openai_summary_deployment_name = "gpt-4.1-nano"

# Optional: full resource ID for automatic RBAC assignment
# ai_services_resource_id = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<name>"

# ── Fabric Data Agent ──────────────────────────────────────────
# enable_fabric_data_agent  = true
# fabric_data_agent_mcp_url = "https://api.fabric.microsoft.com/v1/mcp/workspaces/<id>/dataagents/<id>/agent"

# Fabric capacity status check (optional — enables green/red indicator in UI)
# fabric_capacity_resource_id = "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.Fabric/capacities/<name>"

# ── Easy Auth (Entra ID login + Fabric user tokens) ───────────
# Gates the entire app behind Entra ID login. Required for Fabric Data Agent
# in production (Fabric requires user identity tokens for data queries).
#
# Terraform creates: Entra app registration, client secret, admin consent
# grants, token store (storage account), and ACA Easy Auth configuration.
#
# After apply, run: ./post_infra_deploy.sh
# One manual step: add the MI to your Fabric workspace as Admin.

# enable_easy_auth = true
# easyauth_storage_account_name = ""  # auto-generated if empty
#
# When Easy Auth is enabled, Terraform also creates:
#   - {app_name}-App-Users security group (controls who can log in)
#   - {app_name}-Data-Users security group (controls Fabric data access)
#   - appRoleAssignmentRequired = true (only assigned users/groups can log in)
#
# After apply:
#   1. Run ./post_infra_deploy.sh
#   2. Add the MI to your Fabric workspace as Admin
#   3. Add the Data-Users group to Fabric workspace as Viewer
#   4. Use ./add_user.sh to onboard users

# ── Email notifications ────────────────────────────────────────
# Sender mailbox for Graph Mail API notifications. Leave empty to disable.
# Requires Mail.Send app permission on the managed identity.
# mail_sender_address = "admin@contoso.com"

# ── VNet integration ──────────────────────────────────────────
# Places the ACA environment into a customer-managed VNet with a private
# endpoint for the token store.  Required when org policy mandates
# publicNetworkAccess=Disabled on storage accounts.
#
# ⚠️  IMPORTANT: Enabling VNet on an existing deployment will RECREATE the
# ACA Environment (destroy + create).  Plan a maintenance window.
# The app registration redirect URI auto-updates via Terraform, but verify
# after apply.
#
# enable_vnet       = true
# vnet_address_space = "10.0.0.0/16"   # default
# aca_subnet_cidr    = "10.0.0.0/23"   # /23 minimum for ACA
# pe_subnet_cidr     = "10.0.2.0/24"   # for private endpoints

# ── Persistent history storage ─────────────────────────────────
# Stores run history in Azure Blob Storage so it survives ACA redeploys
# and restarts.  Without this, history is lost on every deployment.
#
# enable_history_storage       = true
# history_storage_account_name = ""   # auto-generated if empty
# history_retention_days       = 90   # auto-delete after N days (0 = never)

# ── Observability ───────────────────────────────────────────────
# Disabled by default. Enable only after reviewing telemetry cost and privacy
# implications for prompts, traces, logs, and tool metadata.
#
# enable_instrumentation = true
