PROJECT_ENDPOINT=https://<FOUNDRY>.services.ai.azure.com/api/projects/<PROJECT_NAME>
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5.1

# Observability — Azure AI Foundry setup (auto-retrieves App Insights from project)
ENABLE_INSTRUMENTATION=true
# ENABLE_SENSITIVE_DATA=true          # ⚠️ Only in dev — logs prompts, responses, tool args
# OTEL_SERVICE_NAME=multi-agent-travel
# ENABLE_CONSOLE_EXPORTERS=true       # Fallback: print spans to console
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # Fallback: Aspire Dashboard / OTLP collector

# Graph Mail — send final response email from admin mailbox via Managed Identity
# Requires Mail.Send application permission granted to the MI service principal
# MAIL_SENDER_ADDRESS=admin@yourdomain.com
