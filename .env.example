# ─────────────────────────────────────────────────────────
# Core — Azure AI Foundry + Azure OpenAI
# ─────────────────────────────────────────────────────────

# (required for Foundry agents) Azure AI Foundry project endpoint
PROJECT_ENDPOINT=https://<FOUNDRY>.services.ai.azure.com/api/projects/<PROJECT_NAME>

# (required) Azure OpenAI endpoint used by the orchestrator
AZURE_OPENAI_ENDPOINT=https://<RESOURCE>.openai.azure.com/

# (optional, default: gpt-4o) Orchestrator chat model deployment name
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o

# (optional, default: gpt-4.1-nano) Model used for event summarization
AZURE_OPENAI_SUMMARY_DEPLOYMENT_NAME=gpt-4.1-nano

# ─────────────────────────────────────────────────────────
# Web / CORS
# ─────────────────────────────────────────────────────────

# (optional, default: *) Comma-separated CORS allowed origins
# Use "*" for local dev; restrict in production (e.g. https://myapp.azurecontainerapps.io)
# ALLOWED_ORIGINS=https://myapp.azurecontainerapps.io

# ─────────────────────────────────────────────────────────
# Identity & Auth
# ─────────────────────────────────────────────────────────

# (optional, deployed env only) Managed identity client ID for Azure Container Apps
# When set, DefaultAzureCredential uses this specific managed identity
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# (optional) Super-user email — this user can view all users' run history
# SUPER_USER_EMAIL=admin@contoso.com

# ─────────────────────────────────────────────────────────
# Graph Mail — send final response email from admin mailbox
# ─────────────────────────────────────────────────────────

# (optional, empty = disabled) Admin mailbox address for Graph Mail.Send
# Requires Mail.Send application permission granted to the MI service principal
# MAIL_SENDER_ADDRESS=admin@yourdomain.com

# ─────────────────────────────────────────────────────────
# Fabric Data Agent (MCP)
# ─────────────────────────────────────────────────────────

# (optional) Fabric Data Agent MCP endpoint URL
# FABRIC_DATA_AGENT_MCP_URL=https://<WORKSPACE>.fabric.microsoft.com/...

# (optional) Full ARM resource ID for Fabric capacity — used for capacity status checks
# FABRIC_CAPACITY_RESOURCE_ID=/subscriptions/<SUB>/resourceGroups/<RG>/providers/Microsoft.Fabric/capacities/<NAME>

# ─────────────────────────────────────────────────────────
# Observability — Azure AI Foundry + OpenTelemetry
# ─────────────────────────────────────────────────────────

# (optional, default: false) Enable Azure Monitor / App Insights instrumentation
# When true, auto-retrieves the App Insights connection string from the Foundry project
ENABLE_INSTRUMENTATION=true

# (optional, default: false) ⚠️ Dev only! Logs prompts, responses, and tool args
# ENABLE_SENSITIVE_DATA=true

# (optional) Override the OpenTelemetry service name
# OTEL_SERVICE_NAME=multi-agent-app

# (optional) Enable console span/log exporters as a fallback
# ENABLE_CONSOLE_EXPORTERS=true

# (optional) OTLP collector endpoint (e.g. Aspire Dashboard)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─────────────────────────────────────────────────────────
# Build metadata (set automatically by CI/CD — not user-configured)
# ─────────────────────────────────────────────────────────
# APP_VERSION=1.0.0
# GIT_SHA=abc1234
# BUILD_DATE=2025-01-01T00:00:00Z
